# App
DEFAULT_TICKER=E1VFVN30.VN
DATABASE_URL=sqlite:///./simple_finance.db

# Market data provider: yfinance | http
MARKET_DATA_PROVIDER=yfinance

# HTTP OHLCV provider (when MARKET_DATA_PROVIDER=http)
# Expected JSON: [{"date":"2024-01-01","open":1,"high":2,"low":0.5,"close":1.5}, ...]
MARKET_DATA_BASE_URL=https://api.example.com
MARKET_DATA_OHLCV_PATH=/v1/ohlcv/{ticker}
MARKET_DATA_API_KEY=
MARKET_DATA_START_PARAM=start
MARKET_DATA_END_PARAM=end

# Default watchlist for GET /api/v1/market/summary
MARKET_SUMMARY_SYMBOLS=E1VFVN30.VN,FUEVFVND.VN,VNINDEX.VN

# Strategy defaults
ANNUAL_RF_RATE=0.05
DEFAULT_INITIAL_CASH=10000000
DEFAULT_MONTHLY_CASH=1000000
DEFAULT_FEE_RATE=0.0015
